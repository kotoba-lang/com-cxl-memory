   "memoryregions" {:create create-memory-region :list list-memory-regions :get get-memory-region :update update-memory-region :delete delete-memory-region}
   "flitchannels" {:create create-flit-channel :list list-flit-channels :get get-flit-channel :update update-flit-channel :delete delete-flit-channel}
   "coherencedomains" {:create create-coherence-domain :list list-coherence-domains :get get-coherence-domain :update update-coherence-domain :delete delete-coherence-domain}
