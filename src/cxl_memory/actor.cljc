                   (cond-> (contains? data :latencyNs) (conj [:db/add id :cxl_memory.QosClass/latencyNs (as-double (get data :latencyNs))]))
                   (conj [:db/add id :cxl_memory.QosClass/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-qos-class
  "Delete a QosClass."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

;; ── HotplugEvent ────────────────────────────────────────────────────────────────
(defn create-hotplug-event
  "Create a HotplugEvent."
  [port data]
  (require-fields data ["kind" "slot"])
  (let [id (new-id "cxl_hot")
        e {:db/id id
           :cxl_memory.HotplugEvent/id id
           :cxl_memory.HotplugEvent/deviceId (get data :deviceId)
           :cxl_memory.HotplugEvent/kind (get data :kind)
           :cxl_memory.HotplugEvent/slot (as-long (get data :slot))
           :cxl_memory.HotplugEvent/status (get data :status)
           :cxl_memory.HotplugEvent/createdAt (now)
           :cxl_memory.HotplugEvent/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-hotplug-events
  "List HotplugEvent with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-hotplug-events port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :cxl_memory.HotplugEvent/id))
         rows (apply-filters rows (:filter opts) [:cxl_memory.HotplugEvent/deviceId :cxl_memory.HotplugEvent/kind :cxl_memory.HotplugEvent/slot :cxl_memory.HotplugEvent/status])]
     (paginate rows opts))))

(defn get-hotplug-event
  "Retrieve a HotplugEvent by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-hotplug-event port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-hotplug-event
  "Update a HotplugEvent; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :deviceId) (conj [:db/add id :cxl_memory.HotplugEvent/deviceId (get data :deviceId)]))
                   (cond-> (contains? data :kind) (conj [:db/add id :cxl_memory.HotplugEvent/kind (get data :kind)]))
                   (cond-> (contains? data :slot) (conj [:db/add id :cxl_memory.HotplugEvent/slot (as-long (get data :slot))]))
                   (cond-> (contains? data :status) (conj [:db/add id :cxl_memory.HotplugEvent/status (get data :status)]))
                   (conj [:db/add id :cxl_memory.HotplugEvent/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-hotplug-event
  "Delete a HotplugEvent."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

